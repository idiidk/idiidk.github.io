{"_env":"NODEJS","_serializationMethod":"normal","_autosave":false,"_autosaveInterval":5000,"_collections":[{"name":"items","unindexedSortComparator":"js","defaultLokiOperatorPackage":"js","_dynamicViews":[],"uniqueNames":[],"transforms":{},"rangedIndexes":{},"_data":[{"slug":"b302-website","description":"The website of the company B302","title":"B302 Website","img":"b302.jpeg","toc":[],"body":{"type":"root","children":[{"type":"element","tag":"h1","props":{"id":"b302-website"},"children":[{"type":"element","tag":"a","props":{"ariaHidden":"true","href":"#b302-website","tabIndex":-1},"children":[{"type":"element","tag":"span","props":{"className":["icon","icon-link"]},"children":[]}]},{"type":"text","value":"B302 Website"}]},{"type":"text","value":"\n"},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"B302 is cool"}]}]},"text":"\n# B302 Website\n\nB302 is cool\n","dir":"/work","path":"/work/b302-website","extension":".md","createdAt":"2022-05-12T13:31:30.390Z","updatedAt":"2022-05-12T13:31:30.390Z","meta":{"version":0,"revision":0,"created":1652362360650},"$loki":1},{"slug":"formdesk","description":"A platform that allows students to view reviews of studies abroad","title":"Formdesk","img":"formdesk.jpeg","toc":[],"body":{"type":"root","children":[{"type":"element","tag":"h1","props":{"id":"formdesk"},"children":[{"type":"element","tag":"a","props":{"href":"#formdesk","ariaHidden":"true","tabIndex":-1},"children":[{"type":"element","tag":"span","props":{"className":["icon","icon-link"]},"children":[]}]},{"type":"text","value":"Formdesk"}]},{"type":"text","value":"\n"},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Formdesk is a project I worked on while working at "},{"type":"element","tag":"a","props":{"href":"https://b302.nl","rel":["nofollow","noopener","noreferrer"],"target":"_blank"},"children":[{"type":"text","value":"B302, A creative media mob"}]},{"type":"text","value":". It is a site where students of the HAN University of Applied Sciences can view different metrics of studys abroad to decide if it's right for them. The description that's on the site itself is as follows:"}]},{"type":"text","value":"\n"},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Thinking about studying abroad? Good choice, spending time abroad not only fulfils academic goals, but also lets you experience a new culture, language and environment. Jumping into a new experience can be difficult and overwhelming, but lucky for you, we are here to help!"}]},{"type":"text","value":"\n"},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Here you will find information about our partner universities, based on the experiences of HAN students, who studied there in the past. They have given their impressions about the university, the campus and the country, etc., which will help you prepare for your Study Abroad adventure."}]},{"type":"text","value":"\n"},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"I primarily worked on the front-end of the site which is made in React. I worked in a team of about 5 students working closely together with the back-end team to realise the complete front-end of the site."}]},{"type":"text","value":"\n"},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"The site is currently in production at: "},{"type":"element","tag":"a","props":{"href":"https://formdesk-2.acc.theburo.nl/","rel":["nofollow","noopener","noreferrer"],"target":"_blank"},"children":[{"type":"text","value":"https://formdesk-2.acc.theburo.nl/"}]}]}]},"text":"\n# Formdesk\n\nFormdesk is a project I worked on while working at [B302, A creative media mob](https://b302.nl). It is a site where students of the HAN University of Applied Sciences can view different metrics of studys abroad to decide if it's right for them. The description that's on the site itself is as follows:\n\nThinking about studying abroad? Good choice, spending time abroad not only fulfils academic goals, but also lets you experience a new culture, language and environment. Jumping into a new experience can be difficult and overwhelming, but lucky for you, we are here to help!\n\nHere you will find information about our partner universities, based on the experiences of HAN students, who studied there in the past. They have given their impressions about the university, the campus and the country, etc., which will help you prepare for your Study Abroad adventure.\n\nI primarily worked on the front-end of the site which is made in React. I worked in a team of about 5 students working closely together with the back-end team to realise the complete front-end of the site.\n\nThe site is currently in production at: [https://formdesk-2.acc.theburo.nl/](https://formdesk-2.acc.theburo.nl/)\n","dir":"/work","path":"/work/formdesk","extension":".md","createdAt":"2022-05-12T13:31:30.390Z","updatedAt":"2022-05-12T13:31:30.390Z","meta":{"version":0,"revision":0,"created":1652362360668},"$loki":2}],"idIndex":[1,2],"maxId":2,"_dirty":true,"_nestedProperties":[],"transactional":false,"asyncListeners":false,"disableMeta":false,"disableChangesApi":true,"disableDeltaChangesApi":true,"cloneObjects":false,"cloneMethod":"deep","changes":[],"_fullTextSearch":{"ii":{"title":{"_store":true,"_optimizeChanges":true,"docCount":2,"docStore":[[0,{"fieldLength":2}],[1,{"fieldLength":1}]],"totalFieldLength":3,"root":{"k":[98,119,102],"v":[{"k":[51],"v":[{"k":[48],"v":[{"k":[50],"v":[{"d":{"df":1,"dc":[[0,1]]}}]}]}]},{"k":[101],"v":[{"k":[98],"v":[{"k":[115],"v":[{"k":[105],"v":[{"k":[116],"v":[{"k":[101],"v":[{"d":{"df":1,"dc":[[0,1]]}}]}]}]}]}]}]},{"k":[111],"v":[{"k":[114],"v":[{"k":[109],"v":[{"k":[100],"v":[{"k":[101],"v":[{"k":[115],"v":[{"k":[107],"v":[{"d":{"df":1,"dc":[[1,1]]}}]}]}]}]}]}]}]}]}},"description":{"_store":true,"_optimizeChanges":true,"docCount":2,"docStore":[[0,{"fieldLength":6}],[1,{"fieldLength":11}]],"totalFieldLe